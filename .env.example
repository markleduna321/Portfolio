# Email Service Configuration (Optional - for production email functionality)
# Uncomment and configure one of the following services:

# Option 1: Resend (Recommended for Vercel) - https://resend.com
# RESEND_API_KEY=your_resend_api_key_here

# Option 2: SendGrid - https://sendgrid.com
# SENDGRID_API_KEY=your_sendgrid_api_key_here

# Option 3: AWS SES
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1

